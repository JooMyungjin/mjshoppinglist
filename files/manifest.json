{
  "manifest_version": 3,
  "name": "쇼핑 내역 정리",
  "version": "2.0.2",
  "description": "쿠팡, 네이버쇼핑, 11번가 구매 내역을 수집하고 구글 시트에 저장합니다.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.coupang.com/*",
    "https://*.naver.com/*",
    "https://*.11st.co.kr/*",
    "https://buy.11st.co.kr/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*",
    "https://*.pay.naver.com/*",
    "https://orders.pay.naver.com/*",
    "https://*.aliexpress.com/*",
    "https://api.frankfurter.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "쇼핑 내역 정리"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "app.html",
        "categories.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}